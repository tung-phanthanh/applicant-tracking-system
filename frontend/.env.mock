# =============================================
# ENV FILE CHO MOCK MODE
# Copy file này thành: .env.development.local
# hoặc thêm dòng VITE_MOCK=true vào file .env hiện có
# =============================================

# Bật mock data (không cần backend running)
VITE_MOCK=true

# URL backend (chỉ dùng khi VITE_MOCK=false)
VITE_API_URL=http://localhost:8386/api/v1
